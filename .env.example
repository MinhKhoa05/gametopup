# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
COMPOSE_PROJECT_NAME=gametopup

# --- SHARED DATABASE CONFIG ---
DB_NAME=game_topup_db
DB_USER=game_topup_user
DB_PASSWORD=YOUR_APP_PASSWORD
DB_ROOT_PASSWORD=YOUR_ROOT_PASSWORD

# --- LOCAL NETWORK (Used for 'dotnet run' or external DB tools) ---
DB_HOST=127.0.0.1
DB_PORT=3307

# --- API CONFIG ---
API_PORT_EXTERNAL=5000
ASPNETCORE_ENVIRONMENT=Development

# --- FRONTEND CONFIG ---
FRONTEND_PORT_EXTERNAL=3000
VITE_API_BASE_URL=http://localhost:5000/api

# =============================================================================
# SECURITY & AUTH
# =============================================================================
JWT_KEY=YOUR_SECURE_JWT_KEY_MIN_32_CHARS
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# VIETQR
# =============================================================================
VIETQR_BANK_ID=mbbank
VIETQR_ACCOUNT_NO=YOUR_BANK_ACCOUNT_NO
VIETQR_ACCOUNT_NAME=YOUR_BANK_ACCOUNT_NAME
VIETQR_TEMPLATE=compact2

# =============================================================================
# CLOUDINARY
# =============================================================================
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
CLOUDINARY_FOLDER=gametopup
